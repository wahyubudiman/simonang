FROM node:20-alpine

# Install pnpm globally inside container
RUN npm install -g pnpm

WORKDIR /app

# Copy package.json and pnpm-lock.yaml if exists
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install

# Copy application files
COPY . .

# Vite development server runs on 5173, --host is required to expose it inside container network
CMD ["pnpm", "dev", "--host"]
